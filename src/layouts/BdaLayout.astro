---
import '../styles/bda.css';
import Social from '../components/Social.astro';
import { navFor, href } from '../lib/content.js';
const { title = 'KGM Asia', variant = 'inner', active = '' } = Astro.props;
const nav = navFor('bda');
const isHome = variant === 'home';
const logo = href('logo/logo_banner.png');
const favicon = href('favicon.svg');
---
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <title>{title} — KGM Asia</title>
    <meta name="description" content="KGM Asia — thiết kế & thi công nội thất khách sạn, F&B, biệt thự. Hơn 1000 công trình trong và ngoài nước." />
  </head>
  <body>
    {isHome ? (
      <header class="bda-home-bar">
        <a href={href('bda')} aria-label="KGM Asia"><img class="bda-logo-img" src={logo} alt="KGM Asia" /></a>
        <button class="bda-plus" aria-label="Menu">+</button>
      </header>
    ) : (
      <>
        <aside class="bda-side">
          <a href={href('bda')} aria-label="KGM Asia"><img class="bda-logo-img" src={logo} alt="KGM Asia" /></a>
          <nav class="bda-nav">
            {nav.map((n) => <a href={n.url} class={active === n.path ? 'active' : ''}>{n.label}</a>)}
          </nav>
          <Social />
        </aside>
        <header class="bda-topbar">
          <a href={href('bda')} aria-label="KGM Asia"><img class="bda-logo-img" src={logo} alt="KGM Asia" style="height:26px" /></a>
          <button class="bda-plus" aria-label="Menu">+</button>
        </header>
      </>
    )}

    <div class="bda-menu" id="bdaMenu">
      <div class="top">
        <a href={href('bda')} aria-label="KGM Asia"><img class="bda-logo-img" src={logo} alt="KGM Asia" /></a>
        <button class="close" id="bdaClose" aria-label="Đóng">×</button>
      </div>
      <nav>
        {nav.map((n) => <a href={n.url}>{n.label}</a>)}
      </nav>
      <Social />
    </div>

    {isHome ? <slot /> : <main class="bda-main"><slot /></main>}

    <script>
      const menu = document.getElementById('bdaMenu');
      document.querySelectorAll('.bda-plus').forEach((b) => b.addEventListener('click', () => menu?.classList.add('open')));
      document.getElementById('bdaClose')?.addEventListener('click', () => menu?.classList.remove('open'));
    </script>
  </body>
</html>
