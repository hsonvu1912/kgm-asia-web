---
import BdaLayout from '../../../layouts/BdaLayout.astro';
import { posts, cleanHtml, href } from '../../../lib/content.js';
export function getStaticPaths() {
  return posts.filter((p) => p.slug).map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}
const { post } = Astro.props;
const fmt = (d) => { const t = new Date(d); return `${String(t.getDate()).padStart(2,'0')}/${String(t.getMonth()+1).padStart(2,'0')}/${t.getFullYear()}`; };
---
<BdaLayout title={post.title} active="tin-tuc">
  <div style="max-width:720px">
    <div class="lbl" style="margin-bottom:6px">{fmt(post.date)}</div>
    <h1 style="font-size:26px;font-weight:500;line-height:1.3;margin:0 0 20px">{post.title}</h1>
    <div class="rich" set:html={cleanHtml(post.html)} />
    <div class="bda-foot-nav"><a href={href('bda/tin-tuc')}>← Tất cả tin tức</a></div>
  </div>
</BdaLayout>
