---
import BdaLayout from '../../layouts/BdaLayout.astro';
import { aboutPage, companyPage, projectTypes, titleVi, cleanHtml } from '../../lib/content.js';
---
<BdaLayout title="Về chúng tôi" active="ve-chung-toi">
  <div class="bda-main-inner" style="max-width:720px">
    <div class="lbl">Tầm nhìn</div>
    <p class="lead">KGM Asia — kiến tạo những không gian sống bền vững, tinh tế và giàu bản sắc cho khách sạn, F&B và biệt thự.</p>

    <div class="lbl">Giới thiệu</div>
    {aboutPage && <div class="rich" set:html={cleanHtml(aboutPage.html)} />}
    {companyPage && <div class="rich" set:html={cleanHtml(companyPage.html)} />}

    <div class="lbl">Năng lực</div>
    <div class="rich">
      <ul>
        {projectTypes.map((t) => <li>{titleVi(t.name)} ({t.count} công trình)</li>)}
      </ul>
    </div>
  </div>
</BdaLayout>
