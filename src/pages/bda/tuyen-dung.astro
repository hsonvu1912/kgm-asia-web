---
import BdaLayout from '../../layouts/BdaLayout.astro';
import { recruitPage, cleanHtml, site } from '../../lib/content.js';
---
<BdaLayout title="Tuyển dụng" active="tuyen-dung">
  <div style="max-width:720px">
    <div class="lbl">Tuyển dụng</div>
    <p class="lead">Gia nhập đội ngũ KGM Asia.</p>
    {recruitPage ? (
      <div class="rich" set:html={cleanHtml(recruitPage.html)} />
    ) : (
      <p class="rich">Gửi CV về <a href={`mailto:${site.email}`}>{site.email}</a> hoặc gọi {site.phone}.</p>
    )}
  </div>
</BdaLayout>
