---
import BdaLayout from '../../layouts/BdaLayout.astro';
import { site } from '../../lib/content.js';
const directions = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.mapQuery)}`;
---
<BdaLayout title="Liên hệ" active="lien-he">
  <div style="max-width:760px">
    <div class="contact-cols">
      <div>
        <h2>Văn phòng</h2>
        <div class="v">
          {site.legalName}<br />
          {site.address}<br />
          <a class="muted" href={directions} target="_blank" rel="noopener">Chỉ đường ↗</a>
        </div>
        <h2 style="margin-top:34px">Bản tin</h2>
        <div class="v muted">Đăng ký nhận tin từ KGM Asia.</div>
        <form class="nl" onsubmit="return false">
          <input type="email" placeholder="Email của bạn…" aria-label="Email" />
          <button type="submit">Đăng ký</button>
        </form>
      </div>
      <div>
        <h2>Liên hệ</h2>
        <div class="v">
          <a href={`tel:${site.phoneRaw}`}>{site.phone}</a><br />
          <a href={`mailto:${site.email}`}>{site.email}</a><br />
          <span class="muted">Zalo: {site.zalo}</span>
        </div>
        <h2 style="margin-top:34px">Tuyển dụng</h2>
        <div class="v"><a href={`mailto:${site.email}`}>{site.email}</a></div>
      </div>
    </div>
  </div>
</BdaLayout>
