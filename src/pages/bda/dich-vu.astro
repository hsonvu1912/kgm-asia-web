---
import BdaLayout from '../../layouts/BdaLayout.astro';
import { servicesPage, servicesDetail, cleanHtml } from '../../lib/content.js';
---
<BdaLayout title="Dịch vụ" active="dich-vu">
  <div style="max-width:720px">
    <div class="lbl">Dịch vụ</div>
    <p class="lead">Thiết kế & thi công trọn gói — từ ý tưởng, kiến trúc, nội thất đến hoàn thiện.</p>
    {servicesPage && <div class="rich" set:html={cleanHtml(servicesPage.html)} />}
    {servicesDetail && <div class="rich" set:html={cleanHtml(servicesDetail.html)} />}
  </div>
</BdaLayout>
