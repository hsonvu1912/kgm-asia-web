---
import MqLayout from '../../layouts/MqLayout.astro';
import AboutSide from '../../components/mq/AboutSide.astro';
import { aboutPage, projectTypes, cleanHtml } from '../../lib/content.js';
---
<MqLayout title="Về chúng tôi" active="ve-chung-toi">
  <div class="page">
    <AboutSide active="ve-chung-toi" />
    <div class="content">
      <h1 class="h-sec">Về chúng tôi</h1>
      {aboutPage && <div class="rich" set:html={cleanHtml(aboutPage.html)} />}
      <h2 class="h-sec" style="margin-top:36px">Năng lực</h2>
      <div class="rich">
        <ul>
          {projectTypes.map((t) => <li>{t.name} — {t.count} công trình</li>)}
        </ul>
      </div>
    </div>
  </div>
</MqLayout>
