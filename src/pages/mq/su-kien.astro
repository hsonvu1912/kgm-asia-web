---
import MqLayout from '../../layouts/MqLayout.astro';
import Social from '../../components/Social.astro';
import { page, cleanHtml, href } from '../../lib/content.js';
const ev = page('su-kien');
---
<MqLayout title="Sự kiện" active="">
  <div class="page">
    <aside class="side">
      <a href={href('mq/ve-chung-toi')}>Giới thiệu</a>
      <a href={href('mq/dich-vu')}>Dịch vụ</a>
      <a class="active">Sự kiện</a>
      <a href={href('mq/tuyen-dung')}>Tuyển dụng</a>
      <Social />
    </aside>
    <div class="content">
      <h1 class="h-sec">Sự kiện</h1>
      {ev && <div class="rich" set:html={cleanHtml(ev.html)} />}
    </div>
  </div>
</MqLayout>
