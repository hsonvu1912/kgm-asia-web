---
import MqLayout from '../../layouts/MqLayout.astro';
import Social from '../../components/Social.astro';
import { site, href } from '../../lib/content.js';
const directions = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.mapQuery)}`;
---
<MqLayout title="Liên hệ" active="lien-he">
  <div class="page">
    <aside class="side">
      <a class="active">Văn phòng</a>
      <a href={href('mq/ve-chung-toi')}>Về chúng tôi</a>
      <Social />
    </aside>
    <div class="content">
      <h2 class="contact-h">Hà Nội</h2>
      <p class="contact-addr">
        {site.legalName}<br />
        {site.address}<br />
        <a href={directions} target="_blank" rel="noopener" class="gd">Chỉ đường ↗</a>
      </p>
      <p class="contact-addr">
        Điện thoại: <a href={`tel:${site.phoneRaw}`}>{site.phone}</a><br />
        Email: <a href={`mailto:${site.email}`}>{site.email}</a><br />
        Zalo: {site.zalo}
      </p>
      <div style="margin-top:18px"><Social /></div>
    </div>
  </div>
</MqLayout>
